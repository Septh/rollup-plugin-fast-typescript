{
  "name": "rollup-plugin-fast-typescript",
  "version": "3.0.0",
  "description": "A plugin that uses esbuild, swc or sucrase (you decide!) for blazing fast TypeScript transpilation.",
  "author": "Stephan 'Septh' Schreiber <septh@sfr.fr>",
  "keywords": [
    "rollup",
    "plugin",
    "typescript",
    "esbuild",
    "swc",
    "sucrase"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Septh/rollup-plugin-fast-typescript#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Septh/rollup-plugin-fast-typescript.git"
  },
  "bugs": "https://github.com/Septh/rollup-plugin-fast-typescript/issues",
  "funding": [
    {
      "type": "patreon",
      "url": "https://patreon.com/Septh"
    },
    {
      "type": "paypal",
      "url": "https://paypal.me/septh07"
    }
  ],
  "files": [
    "dist",
    "!*.d.ts",
    "!*.map",
    "dist/index.d.ts"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "exports": {
    "types": "./dist/index.d.ts",
    "default": "./dist/index.js"
  },
  "imports": {
    "#package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist",
    "check": "tsc --noEmit --skipLibCheck",
    "prebuild": "npm run clean",
    "build": "npm run buildOnly",
    "buildOnly": "npm run build:js && npm run build:dts",
    "build:js": "tsc -p tsconfig.build.json --declaration false --declarationMap false --removeComments",
    "build:dts": "tsc -p tsconfig.build.json --noCheck --declaration --emitDeclarationOnly",
    "pretest": "npm run build",
    "test": "npm run testOnly",
    "testOnly": "echo \"Error: no test yet\" && exit 1",
    "lint": "eslint source/index.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "type-fest": "^5.5.0"
  },
  "peerDependencies": {
    "@swc/core": "^1.3.100",
    "esbuild": ">=0.25.0",
    "rollup": "^4.17.0",
    "sucrase": "^3.35.0",
    "typescript": "^5.9.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "@swc/core": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    },
    "sucrase": {
      "optional": true
    }
  },
  "devDependencies": {
    "@swc/core": "^1.15.18",
    "@types/node": "^24.12.2",
    "esbuild": "^0.28.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.0",
    "sucrase": "^3.35.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  }
}

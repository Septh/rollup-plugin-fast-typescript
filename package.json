{
  "name": "rollup-plugin-fast-typescript",
  "version": "3.0.0-dev.0",
  "description": "A plugin that uses esbuild, swc or sucrase (you decide!) for blazing fast TypeScript transpilation.",
  "author": "Stephan 'Septh' Schreiber <septh@sfr.fr>",
  "keywords": [
    "rollup",
    "plugin",
    "typescript",
    "esbuild",
    "swc",
    "sucrase"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Septh/rollup-plugin-fast-typescript#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Septh/rollup-plugin-fast-typescript.git"
  },
  "bugs": "https://github.com/Septh/rollup-plugin-fast-typescript/issues",
  "funding": [
    {
      "type": "patreon",
      "url": "https://patreon.com/Septh"
    },
    {
      "type": "paypal",
      "url": "https://paypal.me/septh07"
    }
  ],
  "files": [
    "build",
    "!*.d.ts",
    "!*.map",
    "build/index.d.ts"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    }
  },
  "imports": {
    "#package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf build",
    "build": "rimraf build && tsc",
    "check": "tsc --noEmit --skipLibCheck",
    "prepublishOnly": "rimraf build && tsc --removeComments --declaration false && tsc --emitDeclarationOnly"
  },
  "dependencies": {
    "type-fest": "^5.5.0"
  },
  "peerDependencies": {
    "@swc/core": "^1.3.100",
    "esbuild": ">=0.25.0",
    "rollup": "^4.17.0",
    "sucrase": "^3.35.0",
    "typescript": "^5.3.0"
  },
  "peerDependenciesMeta": {
    "@swc/core": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    },
    "sucrase": {
      "optional": true
    }
  },
  "devDependencies": {
    "@swc/core": "^1.15.18",
    "@types/node": "^20.19.37",
    "esbuild": "^0.28.0",
    "rollup": "^4.60.0",
    "sucrase": "^3.35.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  }
}
